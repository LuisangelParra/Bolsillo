{
  "$meta": {
    "name": "Bolsillo Design Tokens",
    "version": "1.0.0",
    "source": "docs/design/Bolsillo.dc.html (canonical visual reference)",
    "updated": "2026-06-13",
    "notes": [
      "Light values are extracted verbatim from the canonical mock.",
      "Dark values are a derived proposal — no dark mockup exists yet; refine when one ships.",
      "Both native apps (Android, iOS) MUST map these tokens; do not hardcode hex in UI code.",
      "Money values always use tabular figures (font-variant-numeric: tabular-nums)."
    ]
  },

  "color": {
    "comment": "Semantic roles. Each role has light + dark. Brand violet is constant across modes.",

    "background":          { "light": "#F4F3F6", "dark": "#121016" },
    "surface":             { "light": "#FFFFFF", "dark": "#1C1A22" },
    "surfaceAlt":          { "light": "#F7F6FA", "dark": "#242230" },
    "surfaceInverse":      { "light": "#16161B", "dark": "#2A2833" },
    "onSurfaceInverse":    { "light": "#FFFFFF", "dark": "#FFFFFF" },

    "primary":             { "light": "#7C5CF0", "dark": "#9B7BF5" },
    "primaryContainer":    { "light": "#EDE7FE", "dark": "#2E2748" },
    "onPrimary":           { "light": "#FFFFFF", "dark": "#FFFFFF" },
    "onPrimaryContainer":  { "light": "#6B4FD8", "dark": "#CDBEFF" },
    "primaryAccent":       { "light": "#B79CFF", "dark": "#B79CFF" },

    "textPrimary":         { "light": "#16161C", "dark": "#F2F1F5" },
    "textSecondary":       { "light": "#56565F", "dark": "#B6B5C0" },
    "textMuted":           { "light": "#9A9AA4", "dark": "#82808C" },
    "textDisabled":        { "light": "#C4C3CC", "dark": "#5A5862" },

    "outline":             { "light": "#E7E6EC", "dark": "#2F2D38" },
    "divider":             { "light": "#F2F1F5", "dark": "#26242E" },
    "track":               { "light": "#F0EFF4", "dark": "#2A2833" },
    "fill":                { "light": "#E7E6EC", "dark": "#2F2D38" },
    "sheetHandle":         { "light": "#D6D5DC", "dark": "#3A3844" },

    "success":             { "light": "#16B364", "dark": "#2FD17E" },
    "successContainer":    { "light": "#DCF5E9", "dark": "#123226" },
    "onSuccessContainer":  { "light": "#0E8049", "dark": "#8DEBBC" },

    "danger":              { "light": "#F0425A", "dark": "#FF6378" },
    "dangerContainer":     { "light": "#FDE6EC", "dark": "#3A1620" },
    "onDangerContainer":   { "light": "#C32A40", "dark": "#FFB3BF" },

    "warning":             { "light": "#E0852B", "dark": "#F0A94E" },
    "warningContainer":    { "light": "#FBEFD6", "dark": "#3A2E14" },
    "warningBorder":       { "light": "#F0DBB0", "dark": "#5C4A1E" },
    "onWarningContainer":  { "light": "#B36514", "dark": "#FAD79A" },

    "info":                { "light": "#3B82F6", "dark": "#5C9CFF" },
    "infoContainer":       { "light": "#E3EFFE", "dark": "#14233A" },

    "amountPositive":      { "light": "#16B364", "dark": "#2FD17E" },
    "amountNegative":      { "light": "#F0425A", "dark": "#FF6378" },
    "notificationDot":     { "light": "#FF5470", "dark": "#FF5470" },
    "caret":               { "light": "#7C5CF0", "dark": "#9B7BF5" }
  },

  "gradient": {
    "hero":        "linear-gradient(162deg, #A98CF5 0%, #8862EE 48%, #6E45DF 100%)",
    "primary":     "linear-gradient(135deg, #9B7BF5 0%, #7C5CF0 100%)",
    "fab":         "linear-gradient(150deg, #9B7BF5 0%, #7C5CF0 100%)",
    "avatar":      "linear-gradient(135deg, #FFD9A8 0%, #F2A65A 100%)",
    "navScrim":    "linear-gradient(to top, #FFFFFF 62%, rgba(255,255,255,0) 100%)"
  },

  "category": {
    "comment": "Palette keyed by token id -> icon foreground + container fill. fg is shared across modes; container has light/dark. Taxonomy nodes (../taxonomy/category-taxonomy.json) map to these via `colorToken`; resolve a transaction's color as taxonomy[categoryId].colorToken -> category[token]. `viajes` is a spare palette entry with no current taxonomy node.",
    "cafe":           { "fg": "#E0A12B", "container": { "light": "#FBEFD6", "dark": "#3A2E14" } },
    "mercado":        { "fg": "#16B364", "container": { "light": "#DCF5E9", "dark": "#123226" } },
    "restaurantes":   { "fg": "#F2843B", "container": { "light": "#FCEBDD", "dark": "#3A2614" } },
    "transporte":     { "fg": "#3B82F6", "container": { "light": "#E3EFFE", "dark": "#14233A" } },
    "ropa":           { "fg": "#7C5CF0", "container": { "light": "#EDE7FE", "dark": "#2E2748" } },
    "ocio":           { "fg": "#2BA4D9", "container": { "light": "#DEF1FB", "dark": "#102E3A" } },
    "salud":          { "fg": "#F0425A", "container": { "light": "#FDE6EC", "dark": "#3A1620" } },
    "vivienda":       { "fg": "#12A89A", "container": { "light": "#DAF3F0", "dark": "#0E3330" } },
    "servicios":      { "fg": "#7C5CF0", "container": { "light": "#EDE7FE", "dark": "#2E2748" } },
    "educacion":      { "fg": "#3B82F6", "container": { "light": "#E3EFFE", "dark": "#14233A" } },
    "viajes":         { "fg": "#2BA4D9", "container": { "light": "#DEF1FB", "dark": "#102E3A" } },
    "otros":          { "fg": "#75757F", "container": { "light": "#ECECEF", "dark": "#2A2833" } },
    "ingreso":        { "fg": "#16B364", "container": { "light": "#DCF5E9", "dark": "#123226" } }
  },

  "chartPalette": ["#7C5CF0", "#3B82F6", "#16B364", "#F2843B", "#2BA4D9", "#E0A12B", "#F0425A", "#12A89A"],

  "typography": {
    "fontFamily": {
      "primary": "Plus Jakarta Sans",
      "fallback": ["system-ui", "sans-serif"]
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "role": {
      "comment": "size & lineHeight in px. tabular=true means use tabular figures (money).",
      "displayBalance": { "size": 46, "lineHeight": 50, "weight": 800, "letterSpacing": -1.0, "tabular": true },
      "displayAmount":  { "size": 52, "lineHeight": 56, "weight": 800, "letterSpacing": -1.5, "tabular": true },
      "moneyXL":        { "size": 27, "lineHeight": 32, "weight": 800, "tabular": true },
      "moneyL":         { "size": 26, "lineHeight": 30, "weight": 800, "tabular": true },
      "keypadDigit":    { "size": 23, "lineHeight": 28, "weight": 700 },
      "titleXL":        { "size": 21, "lineHeight": 26, "weight": 800 },
      "titleL":         { "size": 18, "lineHeight": 24, "weight": 800 },
      "titleM":         { "size": 17, "lineHeight": 22, "weight": 700 },
      "button":         { "size": 16, "lineHeight": 20, "weight": 800 },
      "bodyStrong":     { "size": 15.5, "lineHeight": 20, "weight": 700 },
      "amountRow":      { "size": 15.5, "lineHeight": 20, "weight": 800, "tabular": true },
      "body":           { "size": 14.5, "lineHeight": 20, "weight": 600 },
      "bodyValue":      { "size": 14.5, "lineHeight": 20, "weight": 700 },
      "label":          { "size": 13, "lineHeight": 16, "weight": 600 },
      "labelSmall":     { "size": 12.5, "lineHeight": 16, "weight": 600 },
      "caption":        { "size": 12, "lineHeight": 15, "weight": 500 },
      "badge":          { "size": 11.5, "lineHeight": 14, "weight": 700 },
      "navLabel":       { "size": 11, "lineHeight": 13, "weight": 500 },
      "overline":       { "size": 12.5, "lineHeight": 16, "weight": 700, "letterSpacing": 0.5, "transform": "uppercase" }
    }
  },

  "spacing": {
    "comment": "px scale. Screen horizontal padding = 18 (home) to 20 (sheets).",
    "xxs": 2, "xs": 4, "s": 6, "sm": 8, "m": 10, "base": 12,
    "ml": 14, "l": 16, "xl": 18, "xxl": 20, "3xl": 22, "4xl": 24, "5xl": 26, "6xl": 30
  },

  "radius": {
    "comment": "px corner radii by role. full = pill/circle.",
    "iconTileSm": 11,
    "iconTile": 13,
    "iconTileLg": 17,
    "control": 16,
    "chip": 16,
    "card": 18,
    "cardLarge": 20,
    "cardXL": 22,
    "nav": 26,
    "sheet": 30,
    "frame": 46,
    "full": 9999
  },

  "elevation": {
    "comment": "Box shadows. Ambient color is dark-violet rgba(28,20,60,a) in light mode; use rgba(0,0,0,a) in dark mode.",
    "e1":            { "light": "0 3px 10px rgba(28,20,60,0.05)", "dark": "0 3px 10px rgba(0,0,0,0.40)" },
    "key":           { "light": "0 3px 9px rgba(28,20,60,0.05)",  "dark": "0 3px 9px rgba(0,0,0,0.40)" },
    "e2":            { "light": "0 4px 14px rgba(28,20,60,0.04)", "dark": "0 4px 14px rgba(0,0,0,0.40)" },
    "e2b":           { "light": "0 5px 16px rgba(28,20,60,0.04)", "dark": "0 5px 16px rgba(0,0,0,0.42)" },
    "e3":            { "light": "0 6px 18px rgba(28,20,60,0.05)", "dark": "0 6px 18px rgba(0,0,0,0.45)" },
    "e4":            { "light": "0 8px 22px rgba(28,20,60,0.06)", "dark": "0 8px 22px rgba(0,0,0,0.48)" },
    "nav":           { "light": "0 10px 30px rgba(28,20,60,0.10)","dark": "0 10px 30px rgba(0,0,0,0.55)" },
    "fab":           { "light": "0 10px 26px rgba(124,92,240,0.50)", "dark": "0 10px 26px rgba(124,92,240,0.55)" },
    "buttonPrimary": { "light": "0 10px 24px rgba(124,92,240,0.35)", "dark": "0 10px 24px rgba(124,92,240,0.45)" },
    "segmentedThumb":{ "light": "0 2px 6px rgba(28,20,60,0.07)",  "dark": "0 2px 6px rgba(0,0,0,0.40)" },
    "toast":         { "light": "0 12px 30px rgba(0,0,0,0.30)",   "dark": "0 12px 30px rgba(0,0,0,0.60)" }
  },

  "confidence": {
    "comment": "Maps ExpenseClassifier confidence to visual state. Threshold = ExpenseClassifier default 0.75 (constitution Art. V); the mock used 0.7 — treat 0.75 as source of truth.",
    "threshold": 0.75,
    "states": {
      "waiting": { "when": "conf <= 0",                 "icon": "spark", "fg": "textMuted",        "container": "fill",             "labelKey": "record.ai.waiting" },
      "low":     { "when": "0 < conf < threshold",      "icon": "info",  "fg": "warning",          "container": "warningContainer", "labelKey": "record.ai.toConfirm", "chipBorder": "warningBorder" },
      "high":    { "when": "conf >= threshold",         "icon": "check", "fg": "success",          "container": "successContainer", "labelKey": "record.ai.confident" }
    }
  },

  "motion": {
    "comment": "Durations in ms; easings as cubic-bezier.",
    "duration": { "fade": 200, "pop": 250, "toast": 300, "sheet": 320, "caretBlink": 1100 },
    "easing":   { "sheet": "cubic-bezier(0.22, 1, 0.36, 1)", "standard": "ease" },
    "undoToastTimeout": 5000,
    "learningToastTimeout": 2400
  },

  "layout": {
    "referenceFrame": { "width": 402, "height": 872 },
    "screenPaddingX": 18,
    "sheetPaddingX": 20,
    "statusBarHeight": 54,
    "bottomNav": { "height": 64, "insetX": 14, "insetBottom": 20, "scrimHeight": 96 },
    "fab": { "size": 62, "borderWidth": 4, "insetBottom": 54 },
    "iconTile": { "sm": 38, "md": 44, "lg": 54 },
    "iconStrokeWidth": 2
  }
}
